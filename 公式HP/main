// ── Colors ─────────────────────────────────────────────────────────
const G = { c1:"#1b4332", c2:"#2d6a4f", c3:"#40916c", c4:"#52b788", c5:"#74c69d", c6:"#b7e4c7", c7:"#d8f3dc", c8:"#f0faf4" };

// ── Helpers ────────────────────────────────────────────────────────
const todayStr = () => new Date().toISOString().split("T")[0];
const getMoodEmoji = (m) => ["","😔","😕","😐","😊","🥰"][m] || "";

function getStreak(records, dogId) {
  const dates = [...new Set(records.filter(r => r.dogId === dogId).map(r => r.date))].sort().reverse();
  if (!dates.length) return 0;
  let streak = 0, cur = todayStr();
  for (const d of dates) {
    if (d === cur) {
      streak++;
      const p = new Date(cur); p.setDate(p.getDate() - 1);
      cur = p.toISOString().split("T")[0];
    } else break;
  }
  return streak;
}

async function stLoad(key, fallback) {
  try { const r = await window.storage.get(key); return r ? JSON.parse(r.value) : fallback; } catch { return fallback; }
}
async function stSave(key, val) {
  try { await window.storage.set(key, JSON.stringify(val)); } catch {}
}

// ── Shared sub-components (defined OUTSIDE main component) ─────────
function PhotoPicker({ value, onChange }) {
  const ref = useRef();
  const handleFile = (e) => {
    const f = e.target.files[0];
    if (!f) return;
    const reader = new FileReader();
    reader.onload = (ev) => onChange(ev.target.result);
    reader.readAsDataURL(f);
  };
  return (
    <div>
      <input ref={ref} type="file" accept="image/*" style={{ display:"none" }} onChange={handleFile} />
      {value ? (
        <div style={{ position:"relative" }}>
          <img src={value} alt="" style={{ width:"100%", borderRadius:12, maxHeight:200, objectFit:"cover" }} />
          <button onClick={() => onChange(null)} style={{ position:"absolute", top:8, right:8, background:"rgba(0,0,0,0.5)", color:"white", border:"none", borderRadius:"50%", width:28, height:28, cursor:"pointer", fontSize:16 }}>✕</button>
        </div>
      ) : (
        <button onClick={() => ref.current.click()} style={{ width:"100%", padding:14, borderRadius:12, border:`2px dashed ${G.c6}`, background:G.c8, color:G.c4, fontSize:13, cursor:"pointer" }}>
          📸 写真を追加（任意）
        </button>
      )}
    </div>
  );
}

function ModalSheet({ show, onClose, title, children }) {
  if (!show) return null;
  return (
    <div style={{ position:"fixed", inset:0, background:"rgba(0,0,0,0.45)", zIndex:200, display:"flex", alignItems:"flex-end", justifyContent:"center" }} onClick={onClose}>
      <div style={{ background:"white", borderRadius:"20px 20px 0 0", padding:22, width:"100%", maxWidth:430, maxHeight:"88vh", overflowY:"auto" }} onClick={(e) => e.stopPropagation()}>
        <div style={{ fontSize:18, fontWeight:700, color:G.c1, marginBottom:16 }}>{title}</div>
        {children}
      </div>
    </div>
  );
}

// ── Main App ───────────────────────────────────────────────────────
export default function WanCareApp() {
  const [tab, setTab]                     = useState("home");
  const [teacherMode, setTeacherMode]     = useState(false);
  const [dogs, setDogs]                   = useState(INIT_DOGS);
  const [curDogId, setCurDogId]           = useState(1);
  const [records, setRecords]             = useState(INIT_RECS);
  const [posts, setPosts]                 = useState(INIT_POSTS);
  const [showRec, setShowRec]             = useState(false);
  const [showPost, setShowPost]           = useState(false);
  const [showDog, setShowDog]             = useState(false);
  const [expandPost, setExpandPost]       = useState(null);
  const [replyText, setReplyText]         = useState("");
  const [celebrate, setCelebrate]         = useState(false);
  const [filterBreed, setFilterBreed]     = useState("すべて");
  const [filterCat, setFilterCat]         = useState("すべて");
  const [aiAdvice, setAiAdvice]           = useState("");
  const [aiLoading, setAiLoading]         = useState(false);
  const [newRec, setNewRec]               = useState({ type:"walk", duration:"", notes:"", mood:4, photo:null });
  const [newPost, setNewPost]             = useState({ title:"", content:"", category:"consult", breed:"トイプードル" });
  const [newDog, setNewDog]               = useState({ name:"", breed:"トイプードル", avatar:"🐶", birth:"", weight:"" });

  useEffect(() => {
    (async () => {
      setDogs(await stLoad("wan_dogs", INIT_DOGS));
      setRecords(await stLoad("wan_recs", INIT_RECS));
      setPosts(await stLoad("wan_posts", INIT_POSTS));
      setCurDogId(await stLoad("wan_cdog", 1));
    })();
  }, []);

  const CARE_TYPES = teacherMode ? CARE_TEACHER : CARE_OWNER;
  const ALL_CARE   = [...CARE_OWNER, ...CARE_TEACHER];
  const dog        = dogs.find(d => d.id === curDogId) || dogs[0];
  const myRecs     = records.filter(r => r.dogId === curDogId);
  const todayRecs  = myRecs.filter(r => r.date === todayStr());
  const streak     = getStreak(records, curDogId);

  const saveRecs  = async (r) => { setRecords(r);  await stSave("wan_recs",  r); };
  const savePosts = async (p) => { setPosts(p);     await stSave("wan_posts", p); };
  const saveDogs  = async (d) => { setDogs(d);      await stSave("wan_dogs",  d); };
  const switchDog = (id) =>      { setCurDogId(id); stSave("wan_cdog", id); };

  function addRecord() {
    const rec = { ...newRec, id:Date.now(), dogId:curDogId, date:todayStr(), time:new Date().toLocaleTimeString("ja-JP", { hour:"2-digit", minute:"2-digit" }) };
    saveRecs([rec, ...records]);
    setShowRec(false);
    setNewRec({ type:"walk", duration:"", notes:"", mood:4, photo:null });
    setCelebrate(true);
    setTimeout(() => setCelebrate(false), 2400);
  }

  function addPost() {
    const p = { ...newPost, id:Date.now(), author:"あなた", avatar:"🐾", likes:0, comments:0, date:todayStr(), replies:[] };
    savePosts([p, ...posts]);
    setShowPost(false);
    setNewPost({ title:"", content:"", category:"consult", breed: dog?.breed || "トイプードル" });
  }

  function addDog() {
    if (!newDog.name.trim()) return;
    const d = { ...newDog, id:Date.now() };
    const updated = [...dogs, d];
    saveDogs(updated);
    switchDog(d.id);
    setShowDog(false);
    setNewDog({ name:"", breed:"トイプードル", avatar:"🐶", birth:"", weight:"" });
  }

  async function fetchAI() {
    if (!myRecs.length) { setAiAdvice("まだ記録がありません。記録を追加してから試してみてね！"); return; }
    setAiLoading(true); setAiAdvice("");
    const summary = myRecs.slice(0, 10).map(r => `${r.date} ${r.type} 気分${r.mood}/5 ${r.notes || ""}`).join("\n");
    try {
      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type":"application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 800,
          messages: [{ role:"user", content:`あなたは犬の健康管理アドバイザーです。以下は「${dog?.name}」(${dog?.breed})の最近の記録です。\n\n${summary}\n\nやさしい日本語で以下を教えてください：\n1. 健康状態で良い点\n2. 気になる点（あれば）\n3. 飼い主へのアドバイス1〜2つ\n\n200字以内で簡潔に。` }]
        })
      });
      const data = await res.json();
      setAiAdvice(data.content?.map(c => c.text || "").join("") || "取得できませんでした");
    } catch { setAiAdvice("AIアドバイスの取得に失敗しました。"); }
    setAiLoading(false);
  }

  // Graph data
  const last7 = Array.from({ length:7 }, (_, i) => {
    const d = new Date(); d.setDate(d.getDate() - i);
    return d.toISOString().split("T")[0];
  }).reverse();
  const graphWalk = last7.map(date => ({
    date: date.slice(5),
    分: myRecs.filter(r => r.date === date && r.type === "walk").reduce((s, r) => s + (r.duration || 0), 0),
  }));
  const graphMood = last7.map(date => {
    const rs = myRecs.filter(r => r.date === date && r.mood);
    return { date: date.slice(5), 気分: rs.length ? +(rs.reduce((s, r) => s + r.mood, 0) / rs.length).toFixed(1) : null };
  });
  const filteredPosts = posts.filter(p =>
    (filterBreed === "すべて" || p.breed === filterBreed) &&
    (filterCat   === "すべて" || p.category === filterCat)
  );

  // ── Shared style helpers ─────────────────────
  const sCard    = { background:"white", borderRadius:16, padding:16, margin:"12px 14px 0", boxShadow:`0 2px 14px ${G.c2}10` };
  const sInput   = { width:"100%", padding:"10px 12px", borderRadius:10, border:`1.5px solid ${G.c7}`, fontSize:14, outline:"none", boxSizing:"border-box", background:G.c8 };
  const sSelect  = { width:"100%", padding:"10px 12px", borderRadius:10, border:`1.5px solid ${G.c7}`, fontSize:14, outline:"none", background:G.c8 };
  const sBtn     = { background:`linear-gradient(135deg,${G.c2},${G.c4})`, color:"white", border:"none", borderRadius:12, padding:"12px 20px", fontSize:14, fontWeight:700, cursor:"pointer", width:"100%" };
  const sBtnSec  = { background:G.c8, color:G.c2, border:`1.5px solid ${G.c7}`, borderRadius:12, padding:"11px 20px", fontSize:14, fontWeight:600, cursor:"pointer", width:"100%" };
  const sLabel   = { fontSize:12, fontWeight:700, color:G.c3, marginBottom:4, marginTop:14, display:"block" };
  const sChip    = (a) => ({ flexShrink:0, padding:"6px 14px", borderRadius:20, border:`1.5px solid ${a ? G.c2 : G.c7}`, background: a ? G.c2 : "white", color: a ? "white" : "#777", fontSize:12, fontWeight:600, cursor:"pointer", whiteSpace:"nowrap" });
  const sHeader  = { background:`linear-gradient(135deg,${G.c1} 0%,${G.c2} 55%,${G.c3} 100%)`, padding:"18px 18px 22px", color:"white" };
  const sSecTtl  = { fontSize:15, fontWeight:700, color:G.c1, marginBottom:10 };

  // ── Dog selector bar ─────────────────────────
  const dogBar = (
    <div style={{ display:"flex", gap:10, overflowX:"auto", padding:"10px 14px 4px", scrollbarWidth:"none" }}>
      {dogs.map(d => (
        <button key={d.id} onClick={() => switchDog(d.id)} style={{ flexShrink:0, display:"flex", flexDirection:"column", alignItems:"center", gap:3, padding:"8px 14px", borderRadius:14, border:`2px solid ${d.id === curDogId ? G.c2 : G.c7}`, background: d.id === curDogId ? G.c7 : "white", cursor:"pointer" }}>
          <span style={{ fontSize:28 }}>{d.avatar}</span>
          <span style={{ fontSize:11, fontWeight:700, color: d.id === curDogId ? G.c2 : "#777" }}>{d.name}</span>
        </button>
      ))}
      <button onClick={() => setShowDog(true)} style={{ flexShrink:0, display:"flex", flexDirection:"column", alignItems:"center", justifyContent:"center", gap:3, padding:"8px 14px", borderRadius:14, border:`2px dashed ${G.c6}`, background:"white", cursor:"pointer", minWidth:60 }}>
        <span style={{ fontSize:22, color:G.c4 }}>＋</span>
        <span style={{ fontSize:10, color:G.c4 }}>追加</span>
      </button>
    </div>
  );

  // ══ HOME tab ══════════════════════════════════
  const homeTab = (
    <div>
      <div style={sHeader}>
        <div style={{ display:"flex", justifyContent:"space-between", alignItems:"flex-start" }}>
          <div>
            <div style={{ fontSize:22, fontWeight:700, letterSpacing:"-0.5px" }}>🐾 WanCare</div>
            <div style={{ fontSize:13, opacity:0.8, marginTop:2 }}>{dog?.name}ちゃんの毎日を記録しよう</div>
          </div>
          <button onClick={() => setTeacherMode(t => !t)} style={{ background:"rgba(255,255,255,0.2)", border:"1px solid rgba(255,255,255,0.35)", borderRadius:20, padding:"5px 12px", color:"white", fontSize:12, fontWeight:700, cursor:"pointer" }}>
            {teacherMode ? "👩‍🏫 先生モード" : "🏠 飼い主モード"}
          </button>
        </div>
        {streak > 0 && (
          <div style={{ display:"inline-flex", alignItems:"center", gap:6, background:"rgba(255,255,255,0.2)", borderRadius:20, padding:"4px 12px", fontSize:13, marginTop:10 }}>
            🔥 {streak}日連続記録中！
          </div>
        )}
      </div>

      {dogBar}

      {todayRecs.length === 0 && (
        <div style={{ ...sCard, background:`linear-gradient(135deg,${G.c7},${G.c6})`, border:"none", boxShadow:"none" }}>
          <div style={{ fontSize:14, color:G.c1, fontWeight:600 }}>🌿 今日はまだ記録がありません</div>
          <div style={{ fontSize:12, color:G.c3, marginTop:4 }}>クイック記録で{dog?.name}の様子を残そう！</div>
        </div>
      )}

      <div style={sCard}>
        <div style={sSecTtl}>{teacherMode ? "📋 業務記録" : "⚡ クイック記録"}</div>
        <div style={{ display:"grid", gridTemplateColumns:`repeat(${Math.min(CARE_TYPES.length, 3)},1fr)`, gap:8 }}>
          {CARE_TYPES.map(t => (
            <button key={t.id} onClick={() => { setNewRec({ ...newRec, type:t.id }); setShowRec(true); }} style={{ background:t.color+"18", border:`1.5px solid ${t.color}30`, borderRadius:12, padding:"12px 6px", cursor:"pointer", textAlign:"center" }}>
              <div style={{ fontSize:24 }}>{t.label.split(" ")[0]}</div>
              <div style={{ fontSize:11, color:G.c2, marginTop:4, fontWeight:600 }}>{t.label.split(" ").slice(1).join(" ")}</div>
            </button>
          ))}
        </div>
      </div>

      <div style={sCard}>
        <div style={sSecTtl}>🤖 AIアドバイス</div>
        <p style={{ fontSize:12, color:"#888", margin:"0 0 12px" }}>{dog?.name}の記録をもとに健康アドバイスをもらえます</p>
        {aiAdvice && (
          <div style={{ background:`linear-gradient(135deg,${G.c8},${G.c7})`, borderRadius:12, padding:14, fontSize:13, color:G.c1, lineHeight:1.75, marginBottom:12, border:`1px solid ${G.c6}` }}>
            {aiAdvice}
          </div>
        )}
        <button style={sBtn} onClick={fetchAI} disabled={aiLoading}>
          {aiLoading ? "🤖 分析中…" : "🤖 AIにアドバイスをもらう"}
        </button>
      </div>

      <div style={sCard}>
        <div style={sSecTtl}>📋 最近の記録</div>
        {myRecs.slice(0, 6).map(r => {
          const type = ALL_CARE.find(t => t.id === r.type) || ALL_CARE[0];
          return (
            <div key={r.id} style={{ display:"flex", gap:12, paddingBottom:14, borderBottom:`1px solid ${G.c8}`, alignItems:"flex-start", marginBottom:2 }}>
              <div style={{ width:36, height:36, borderRadius:"50%", background:type.color+"1a", display:"flex", alignItems:"center", justifyContent:"center", fontSize:18, flexShrink:0, border:`2px solid ${type.color}30` }}>
                {type.label.split(" ")[0]}
              </div>
              <div style={{ flex:1 }}>
                <div style={{ fontSize:13, fontWeight:700, color:G.c1 }}>{type.label} {r.duration ? `${r.duration}分` : ""} {getMoodEmoji(r.mood)}</div>
                <div style={{ fontSize:11, color:"#bbb", marginTop:2 }}>{r.date} {r.time}</div>
                {r.notes && <div style={{ fontSize:12, color:"#555", marginTop:4, background:G.c8, borderRadius:8, padding:"4px 8px" }}>{r.notes}</div>}
                {r.photo && <img src={r.photo} alt="" style={{ width:"100%", borderRadius:10, marginTop:6, maxHeight:120, objectFit:"cover" }} />}
              </div>
            </div>
          );
        })}
        {myRecs.length === 0 && <div style={{ color:"#ccc", fontSize:13, textAlign:"center", padding:16 }}>まだ記録がありません</div>}
      </div>
      <div style={{ padding:"10px 14px 0" }}>
        <button style={sBtn} onClick={() => setShowRec(true)}>＋ 記録を追加</button>
      </div>
      <div style={{ height:10 }} />
    </div>
  );

  // ══ GRAPH tab ══════════════════════════════════
  const graphTab = (
    <div>
      <div style={sHeader}>
        <div style={{ fontSize:22, fontWeight:700 }}>📊 ふり返りグラフ</div>
        <div style={{ fontSize:13, opacity:0.8, marginTop:2 }}>{dog?.name}の7日間のデータ</div>
      </div>
      {dogBar}
      <div style={sCard}>
        <div style={sSecTtl}>🐾 散歩時間（分）</div>
        <ResponsiveContainer width="100%" height={180}>
          <BarChart data={graphWalk} margin={{ left:-10, right:10 }}>
            <CartesianGrid strokeDasharray="3 3" stroke={G.c7} />
            <XAxis dataKey="date" tick={{ fontSize:11 }} />
            <YAxis tick={{ fontSize:11 }} />
            <Tooltip contentStyle={{ borderRadius:10, border:`1px solid ${G.c6}`, fontSize:12 }} />
            <Bar dataKey="分" fill={G.c3} radius={[6,6,0,0]} />
          </BarChart>
        </ResponsiveContainer>
      </div>
      <div style={sCard}>
        <div style={sSecTtl}>🥰 気分スコア推移（/5）</div>
        <ResponsiveContainer width="100%" height={180}>
          <LineChart data={graphMood} margin={{ left:-10, right:10 }}>
            <CartesianGrid strokeDasharray="3 3" stroke={G.c7} />
            <XAxis dataKey="date" tick={{ fontSize:11 }} />
            <YAxis domain={[0,5]} tick={{ fontSize:11 }} />
            <Tooltip contentStyle={{ borderRadius:10, border:`1px solid ${G.c6}`, fontSize:12 }} formatter={v => [`${v} / 5`, ""]} />
            <Line type="monotone" dataKey="気分" stroke={G.c2} strokeWidth={2.5} dot={{ r:5, fill:G.c3 }} connectNulls />
          </LineChart>
        </ResponsiveContainer>
      </div>
      <div style={sCard}>
        <div style={sSecTtl}>📈 累計サマリー</div>
        <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr 1fr", gap:10 }}>
          {[["総記録", myRecs.length, "件"],["散歩回数", myRecs.filter(r => r.type==="walk").length, "回"],["連続日数", streak, "日"]].map(([l, v]) => (
            <div key={l} style={{ background:G.c8, borderRadius:12, padding:"14px 8px", textAlign:"center" }}>
              <div style={{ fontSize:26, fontWeight:700, color:G.c2 }}>{v}</div>
              <div style={{ fontSize:10, color:G.c4, marginTop:2 }}>{l}</div>
            </div>
          ))}
        </div>
      </div>
      <div style={{ height:10 }} />
    </div>
  );

  // ══ COMMUNITY tab ══════════════════════════════
  const communityTab = (
    <div>
      <div style={sHeader}>
        <div style={{ fontSize:22, fontWeight:700 }}>🌿 コミュニティ</div>
        <div style={{ fontSize:13, opacity:0.8, marginTop:2 }}>犬種別の相談・イベント・情報シェア</div>
      </div>
      <div style={{ padding:"10px 0 0" }}>
        <div style={{ padding:"0 14px 4px", fontSize:12, color:"#aaa", fontWeight:700 }}>犬種</div>
        <div style={{ display:"flex", gap:8, overflowX:"auto", padding:"0 14px 8px", scrollbarWidth:"none" }}>
          {["すべて", ...BREEDS.slice(0,7)].map(b => (
            <button key={b} style={sChip(filterBreed === b)} onClick={() => setFilterBreed(b)}>{b}</button>
          ))}
        </div>
        <div style={{ padding:"0 14px 4px", fontSize:12, color:"#aaa", fontWeight:700 }}>カテゴリ</div>
        <div style={{ display:"flex", gap:8, overflowX:"auto", padding:"0 14px 8px", scrollbarWidth:"none" }}>
          {[{ id:"すべて", label:"すべて" }, ...POST_CATS].map(c => (
            <button key={c.id} style={sChip(filterCat === c.id)} onClick={() => setFilterCat(c.id)}>{c.label}</button>
          ))}
        </div>
      </div>

      {filteredPosts.map(post => {
        const cat = POST_CATS.find(c => c.id === post.category) || POST_CATS[0];
        const exp = expandPost === post.id;
        return (
          <div key={post.id} style={{ ...sCard, cursor:"pointer" }} onClick={() => setExpandPost(exp ? null : post.id)}>
            <div style={{ display:"flex", justifyContent:"space-between", alignItems:"flex-start", marginBottom:8 }}>
              <div style={{ display:"flex", gap:8, alignItems:"center" }}>
                <span style={{ fontSize:24 }}>{post.avatar}</span>
                <div>
                  <div style={{ fontSize:12, fontWeight:700, color:G.c1 }}>{post.author}</div>
                  <div style={{ fontSize:11, color:"#ccc" }}>{post.date}</div>
                </div>
              </div>
              <div style={{ display:"flex", gap:4, flexWrap:"wrap", justifyContent:"flex-end" }}>
                <span style={{ background:cat.color+"1a", color:cat.color, borderRadius:20, padding:"2px 10px", fontSize:11, fontWeight:700 }}>{cat.label}</span>
                <span style={{ background:G.c7, color:G.c2, borderRadius:20, padding:"2px 10px", fontSize:11, fontWeight:600 }}>{post.breed}</span>
              </div>
            </div>
            <div style={{ fontSize:14, fontWeight:700, color:G.c1, marginBottom:6 }}>{post.title}</div>
            <div style={{ fontSize:13, color:"#555", lineHeight:1.65, ...(exp ? {} : { overflow:"hidden", display:"-webkit-box", WebkitLineClamp:2, WebkitBoxOrient:"vertical" }) }}>
              {post.content}
            </div>
            {exp && (
              <div style={{ marginTop:12, borderTop:`1px solid ${G.c8}`, paddingTop:12 }}>
                {post.replies?.map((rep, i) => (
                  <div key={i} style={{ background:G.c8, borderRadius:10, padding:"8px 12px", marginBottom:6, fontSize:13 }}>
                    <span style={{ fontWeight:700, color:G.c2 }}>{rep.author}</span>
                    <span style={{ color:"#444", marginLeft:8 }}>{rep.text}</span>
                  </div>
                ))}
                <div style={{ display:"flex", gap:8, marginTop:8 }}>
                  <input
                    style={{ ...sInput, flex:1 }}
                    placeholder="返信を入力..."
                    value={replyText}
                    onChange={e => setReplyText(e.target.value)}
                    onClick={e => e.stopPropagation()}
                  />
                  <button
                    style={{ ...sBtn, width:"auto", padding:"10px 14px", fontSize:13 }}
                    onClick={e => {
                      e.stopPropagation();
                      if (!replyText.trim()) return;
                      savePosts(posts.map(p => p.id === post.id ? { ...p, replies:[...(p.replies||[]), { author:"あなた", text:replyText }], comments:p.comments+1 } : p));
                      setReplyText("");
                    }}
                  >送信</button>
                </div>
              </div>
            )}
            <div style={{ display:"flex", gap:16, marginTop:10, paddingTop:8, borderTop:`1px solid ${G.c8}` }}>
              <button style={{ background:"none", border:"none", fontSize:13, color:"#888", cursor:"pointer" }} onClick={e => { e.stopPropagation(); savePosts(posts.map(p => p.id===post.id ? {...p,likes:p.likes+1} : p)); }}>
                💚 {post.likes}
              </button>
              <span style={{ fontSize:13, color:"#ccc" }}>💬 {post.comments}</span>
              {!exp && <span style={{ fontSize:12, color:G.c5, marginLeft:"auto" }}>タップで詳細 ▼</span>}
            </div>
          </div>
        );
      })}
      <div style={{ padding:"10px 14px 0" }}>
        <button style={sBtn} onClick={() => setShowPost(true)}>✏️ 投稿する</button>
      </div>
      <div style={{ height:10 }} />
    </div>
  );

  // ══ PROFILE tab ════════════════════════════════
  const profileTab = (
    <div>
      <div style={sHeader}>
        <div style={{ fontSize:22, fontWeight:700 }}>🐾 プロフィール</div>
      </div>
      {dogBar}
      {dog && (
        <>
          <div style={sCard}>
            <div style={{ textAlign:"center", padding:"10px 0" }}>
              <div style={{ fontSize:60 }}>{dog.avatar}</div>
              <div style={{ fontSize:20, fontWeight:700, color:G.c1, marginTop:8 }}>{dog.name}</div>
              <div style={{ fontSize:13, color:G.c4 }}>{dog.breed}</div>
              {dog.birth  && <div style={{ fontSize:12, color:"#aaa", marginTop:4 }}>🎂 {dog.birth}</div>}
              {dog.weight && <div style={{ fontSize:12, color:"#aaa" }}>⚖️ {dog.weight} kg</div>}
            </div>
            <div style={{ display:"flex", justifyContent:"center", gap:24, paddingTop:12, borderTop:`1px solid ${G.c8}` }}>
              {[["総記録",myRecs.length],["散歩",myRecs.filter(r=>r.type==="walk").length],["連続",streak]].map(([l,v]) => (
                <div key={l} style={{ textAlign:"center" }}>
                  <div style={{ fontSize:24, fontWeight:700, color:G.c2 }}>{v}</div>
                  <div style={{ fontSize:11, color:"#aaa" }}>{l}</div>
                </div>
              ))}
            </div>
          </div>
          <div style={sCard}>
            <div style={sSecTtl}>プロフィール編集</div>
            <div style={{ display:"flex", gap:10, flexWrap:"wrap", marginBottom:4 }}>
              {DOG_AVATARS.map(a => (
                <button key={a} onClick={() => saveDogs(dogs.map(d => d.id===curDogId ? {...d,avatar:a} : d))} style={{ fontSize:30, padding:8, borderRadius:12, border:`2px solid ${dog.avatar===a?G.c2:G.c7}`, background:dog.avatar===a?G.c7:"white", cursor:"pointer" }}>
                  {a}
                </button>
              ))}
            </div>
            <label style={sLabel}>名前</label>
            <input style={sInput} value={dog.name} onChange={e => saveDogs(dogs.map(d => d.id===curDogId ? {...d,name:e.target.value} : d))} />
            <label style={sLabel}>犬種</label>
            <select style={sSelect} value={dog.breed} onChange={e => saveDogs(dogs.map(d => d.id===curDogId ? {...d,breed:e.target.value} : d))}>
              {BREEDS.map(b => <option key={b}>{b}</option>)}
            </select>
            <label style={sLabel}>誕生日</label>
            <input style={sInput} type="date" value={dog.birth||""} onChange={e => saveDogs(dogs.map(d => d.id===curDogId ? {...d,birth:e.target.value} : d))} />
            <label style={sLabel}>体重 (kg)</label>
            <input style={sInput} type="number" step="0.1" placeholder="例: 3.5" value={dog.weight||""} onChange={e => saveDogs(dogs.map(d => d.id===curDogId ? {...d,weight:e.target.value} : d))} />
          </div>
        </>
      )}
      <div style={{ height:10 }} />
    </div>
  );

  // ══ RENDER ═════════════════════════════════════
  return (
    <div style={{ fontFamily:"'Hiragino Kaku Gothic ProN','Noto Sans JP',sans-serif", background:G.c8, minHeight:"100vh", maxWidth:430, margin:"0 auto", paddingBottom:80 }}>
      <style>{`@keyframes pop { from { transform:scale(0.4); opacity:0; } to { transform:scale(1); opacity:1; } }`}</style>

      {/* Celebration overlay */}
      {celebrate && (
        <div style={{ position:"fixed", inset:0, zIndex:999, pointerEvents:"none", display:"flex", alignItems:"center", justifyContent:"center" }}>
          <div style={{ background:`linear-gradient(135deg,${G.c2},${G.c4})`, color:"white", borderRadius:24, padding:"24px 40px", textAlign:"center", boxShadow:`0 20px 60px ${G.c2}60`, animation:"pop 0.4s cubic-bezier(0.34,1.56,0.64,1)" }}>
            <div style={{ fontSize:48 }}>🐾</div>
            <div style={{ fontSize:20, fontWeight:700, marginTop:8 }}>記録完了！</div>
            <div style={{ fontSize:13, opacity:0.9, marginTop:4 }}>{dog?.name}のことを大切にしてるね💚</div>
          </div>
        </div>
      )}

      {/* Tab content */}
      {tab === "home"      && homeTab}
      {tab === "graph"     && graphTab}
      {tab === "community" && communityTab}
      {tab === "profile"   && profileTab}

      {/* Bottom nav */}
      <nav style={{ position:"fixed", bottom:0, left:"50%", transform:"translateX(-50%)", width:"100%", maxWidth:430, background:"white", borderTop:`1px solid ${G.c7}`, display:"flex", zIndex:100 }}>
        {[["home","🏠","ホーム"],["graph","📊","グラフ"],["community","🌿","コミュニティ"],["profile","🐾","プロフィール"]].map(([id,icon,lbl]) => (
          <button key={id} onClick={() => setTab(id)} style={{ flex:1, padding:"10px 0", background:"none", border:"none", display:"flex", flexDirection:"column", alignItems:"center", gap:2, cursor:"pointer", color: tab===id ? G.c2 : "#bbb", fontSize:10, fontWeight: tab===id ? 700 : 400 }}>
            <span style={{ fontSize:22 }}>{icon}</span>{lbl}
          </button>
        ))}
      </nav>

      {/* Add Record modal */}
      <ModalSheet show={showRec} onClose={() => setShowRec(false)} title="📝 記録を追加">
        <label style={sLabel}>カテゴリ</label>
        <select style={sSelect} value={newRec.type} onChange={e => setNewRec({...newRec,type:e.target.value})}>
          {CARE_TYPES.map(t => <option key={t.id} value={t.id}>{t.label}</option>)}
        </select>
        {(newRec.type==="walk"||newRec.type==="nursery") && (
          <>
            <label style={sLabel}>時間（分）</label>
            <input style={sInput} type="number" placeholder="例：30" value={newRec.duration} onChange={e => setNewRec({...newRec,duration:e.target.value})} />
          </>
        )}
        <label style={sLabel}>気分 {getMoodEmoji(newRec.mood)}</label>
        <div style={{ display:"flex", gap:8, marginBottom:4 }}>
          {[1,2,3,4,5].map(n => (
            <button key={n} style={{ flex:1, padding:8, borderRadius:10, border:`2px solid ${newRec.mood===n?G.c2:"#eee"}`, background:newRec.mood===n?G.c7:"white", fontSize:20, cursor:"pointer" }} onClick={() => setNewRec({...newRec,mood:n})}>
              {getMoodEmoji(n)}
            </button>
          ))}
        </div>
        <label style={sLabel}>写真（任意）</label>
        <PhotoPicker value={newRec.photo} onChange={photo => setNewRec({...newRec,photo})} />
        <label style={sLabel}>メモ</label>
        <textarea style={{ ...sInput, resize:"vertical", minHeight:80 }} placeholder={`${dog?.name}の様子を記録しよう...`} value={newRec.notes} onChange={e => setNewRec({...newRec,notes:e.target.value})} />
        <div style={{ display:"flex", gap:10, marginTop:16 }}>
          <button style={{ ...sBtnSec, flex:1 }} onClick={() => setShowRec(false)}>キャンセル</button>
          <button style={{ ...sBtn, flex:2 }} onClick={addRecord}>記録する 🐾</button>
        </div>
      </ModalSheet>

      {/* Add Post modal */}
      <ModalSheet show={showPost} onClose={() => setShowPost(false)} title="✏️ 投稿を作成">
        <label style={sLabel}>カテゴリ</label>
        <select style={sSelect} value={newPost.category} onChange={e => setNewPost({...newPost,category:e.target.value})}>
          {POST_CATS.map(c => <option key={c.id} value={c.id}>{c.label}</option>)}
        </select>
        <label style={sLabel}>犬種タグ</label>
        <select style={sSelect} value={newPost.breed} onChange={e => setNewPost({...newPost,breed:e.target.value})}>
          {BREEDS.map(b => <option key={b}>{b}</option>)}
        </select>
        <label style={sLabel}>タイトル</label>
        <input style={sInput} placeholder="タイトルを入力" value={newPost.title} onChange={e => setNewPost({...newPost,title:e.target.value})} />
        <label style={sLabel}>内容</label>
        <textarea style={{ ...sInput, resize:"vertical", minHeight:80 }} placeholder="みんなに共有したいことを書こう..." value={newPost.content} onChange={e => setNewPost({...newPost,content:e.target.value})} />
        <div style={{ display:"flex", gap:10, marginTop:16 }}>
          <button style={{ ...sBtnSec, flex:1 }} onClick={() => setShowPost(false)}>キャンセル</button>
          <button style={{ ...sBtn, flex:2 }} onClick={addPost}>投稿する 🌿</button>
        </div>
      </ModalSheet>

      {/* Add Dog modal */}
      <ModalSheet show={showDog} onClose={() => setShowDog(false)} title="🐶 わんこを追加">
        <label style={sLabel}>アイコン</label>
        <div style={{ display:"flex", gap:10, flexWrap:"wrap", marginBottom:4 }}>
          {DOG_AVATARS.map(a => (
            <button key={a} onClick={() => setNewDog({...newDog,avatar:a})} style={{ fontSize:30, padding:8, borderRadius:12, border:`2px solid ${newDog.avatar===a?G.c2:G.c7}`, background:newDog.avatar===a?G.c7:"white", cursor:"pointer" }}>
              {a}
            </button>
          ))}
        </div>
        <label style={sLabel}>名前</label>
        <input style={sInput} placeholder="わんこの名前" value={newDog.name} onChange={e => setNewDog({...newDog,name:e.target.value})} />
        <label style={sLabel}>犬種</label>
        <select style={sSelect} value={newDog.breed} onChange={e => setNewDog({...newDog,breed:e.target.value})}>
          {BREEDS.map(b => <option key={b}>{b}</option>)}
        </select>
        <label style={sLabel}>誕生日（任意）</label>
        <input style={sInput} type="date" value={newDog.birth} onChange={e => setNewDog({...newDog,birth:e.target.value})} />
        <div style={{ display:"flex", gap:10, marginTop:16 }}>
          <button style={{ ...sBtnSec, flex:1 }} onClick={() => setShowDog(false)}>キャンセル</button>
          <button style={{ ...sBtn, flex:2 }} onClick={addDog} disabled={!newDog.name.trim()}>追加する 🐾</button>
        </div>
      </ModalSheet>
    </div>
  );
}
